# Copy this file to .env and fill in the real values. Never commit .env.

# Which published image tag to pull (see docker-compose.yml `image:`).
# The build-and-publish.yml workflow keeps `latest` current with the app
# repo's main branch; pin to a specific commit SHA tag for a reproducible
# deploy that won't move under you.
IMAGE_TAG=latest

# Only used by `docker compose build` (a local build instead of pulling
# the published image) -- which commit/tag/branch of
# ivoed22/gdsn-to-gs1-jsonld to build. Default: main.
APP_GIT_REF=main

# Cloudflare Zero Trust -> Networks -> Tunnels -> create a tunnel ->
# "Docker" connector -> copy the token shown there (a long string
# starting with "ey..."). Do NOT use an API token from a different
# Cloudflare product -- this must be the tunnel's own connector token.
CLOUDFLARE_TUNNEL_TOKEN=
